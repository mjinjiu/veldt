# Veldt Configuration
# Copy to .env and customize for your environment

# AI Backend URL (Python FastAPI service)
AI_SERVICE_URL=http://localhost:8000

# --- HuggingFace model download settings ---
# If the embedding model is already cached locally but network validation
# fails (e.g., behind a proxy), set HF_HUB_OFFLINE=1 to skip online checks.
# HF_HUB_OFFLINE=1

# If huggingface.co is unreachable in your region, use a mirror:
# HF_ENDPOINT=https://hf-mirror.com
